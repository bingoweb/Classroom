{
  "policyVersion": 2,
  "maintenanceMode": true,
  "newFeaturesAllowed": false,
  "permittedMaintenanceChangeTypes": [
    "audit",
    "diagnosis",
    "bugfix",
    "refactor",
    "test",
    "performance",
    "security",
    "accessibility",
    "localisation",
    "documentation"
  ],
  "forbiddenFeatureChangeTypes": [
    "new user-facing features",
    "new cards",
    "new panels",
    "new buttons representing new actions",
    "new tabs",
    "new pages",
    "new API endpoints",
    "new database tables or fields",
    "new persistence mechanisms",
    "new integrations",
    "new runtime dependencies",
    "unrelated redesign",
    "opportunistic cleanup",
    "scope expansion"
  ],
  "applicationPaths": [
    "public/",
    "backend/",
    "database.js",
    "server.js"
  ],
  "testPaths": [
    "tests/"
  ],
  "documentationPaths": [
    "AI_PROJECT_CONTEXT.md",
    "AGENTS.md",
    "README.md",
    ".agent/README.md"
  ],
  "policySensitivePaths": [
    "AGENTS.md",
    "agent-policy.json",
    ".agent/",
    "scripts/verify-agent-compliance.js",
    "tests/agent-compliance.test.js",
    ".githooks/",
    ".github/workflows/",
    ".github/CODEOWNERS"
  ],
  "protectedPaths": [
    ".git/"
  ],
  "prohibitedGitCommands": [
    "git add .",
    "git commit -a",
    "git commit -am",
    "push --force",
    "push -f",
    "amend",
    "rebase",
    "squash"
  ],
  "prohibitedSystemCommands": [
    "killall",
    "pkill"
  ],
  "prohibitedUnsafeDomPatterns": [
    ".innerHTML",
    ".outerHTML",
    "insertAdjacentHTML",
    "document.write",
    "eval(",
    "new Function"
  ],
  "prohibitedTestPatterns": [
    "assert.equal(true, true)",
    "assert.strictEqual(true, true)",
    "assert.ok(true)",
    ".skip(",
    ".todo(",
    "console.assert",
    "placeholder",
    "padding"
  ],
  "prohibitedNetworkAndStoragePatterns": [
    "fetch(",
    "XMLHttpRequest",
    "WebSocket",
    "POST",
    "PUT",
    "PATCH",
    "DELETE",
    "localStorage",
    "sessionStorage",
    "indexedDB",
    "document.cookie",
    "caches.",
    "serviceWorker"
  ],
  "dependencyChangeRules": {
    "allowNewDependencies": false
  },
  "taskContractRequirements": {
    "required": true,
    "directory": ".agent/",
    "schema": "task-contract.schema.json"
  },
  "baselineAndRatchetRules": {
    "enabled": true,
    "file": ".agent/quality-baseline.json",
    "allowGrowth": false
  },
  "languageRules": {
    "userFacingInterface": "Turkish",
    "documentation": "Turkish",
    "technicalIdentifiers": "English",
    "permittedTechnicalLanguageTerms": [
      "ID",
      "API",
      "URL",
      "JSON",
      "HTML",
      "CSS",
      "DOM",
      "Node",
      "Express",
      "Playwright",
      "Chromium",
      "GitHub"
    ]
  },
  "evidenceRules": {
    "localResultsAreNotCI": true,
    "chromiumMustRunIfClaimed": true
  },
  "packageScriptRequirements": {
    "test:core": "Must include all core test files",
    "policy:scan": "node scripts/verify-agent-compliance.js --scan",
    "policy:staged": "node scripts/verify-agent-compliance.js --staged",
    "policy:repository": "node scripts/verify-agent-compliance.js --repository",
    "policy:ci": "node scripts/verify-agent-compliance.js --ci",
    "test:agent-compliance": "node --test tests/agent-compliance.test.js",
    "gate:commit": "npm run policy:staged",
    "gate:project": "npm run policy:repository && npm run test:core",
    "gate:ci": "npm run policy:ci && npm run test:core"
  },
  "adminHtmlRequirements": {
    "file": "public/admin/index.html",
    "requiredIds": [
      "sdeEditableTable",
      "sdeEditableTableBody",
      "sdePreviewTableBody",
      "srpContainer"
    ],
    "requiredHeadings": [
      "#",
      "Tür",
      "Ad",
      "Başlangıç",
      "Bitiş",
      "İşlem"
    ],
    "requiredScriptOrder": [
      "schedule-diagnostics.js",
      "schedule-draft-editor.js",
      "schedule-review-panel.js",
      "admin.js"
    ],
    "prohibitedMarkupPatterns": [
      "style=\"[^\"]*<h3"
    ]
  }
}
